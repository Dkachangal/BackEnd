<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Form Page HTML GET</title>
    <link rel="stylesheet" href="newStyle.css">
    <link rel="stylesheet" href="output.css">

</head>
<body>

  <%- include('partials/navBar') %>

    <h1>Enter Your Details From HTML</h1>
<div class="w-full px-4 py-12"> 
    <form method="post" action="/add-home" 
        class="group relative mx-auto w-full max-w-md p-[1.5px] rounded-3xl bg-gradient-to-br from-blue-500 via-blue-600 to-indigo-700 shadow-lg shadow-blue-500/10 transition-all duration-500 hover:shadow-blue-500/20">
        
        <div class="relative bg-white/95 backdrop-blur-2xl rounded-[22.5px] p-8 overflow-hidden">
            
            <div class="absolute -top-16 -right-16 w-32 h-32 bg-blue-100 rounded-full blur-3xl opacity-40 group-hover:opacity-70 transition-opacity duration-700"></div>
            
            <div class="relative space-y-6">
                <div class="space-y-1">
                    <h2 class="text-2xl font-black text-slate-900 tracking-tight leading-none text-center sm:text-left">New Property</h2>
                    <p class="text-[10px] font-bold text-blue-600/60 uppercase tracking-[0.3em] text-center sm:text-left">Secure Registration</p>
                </div>

                <div class="relative group/input">
                    <input 
                        type="text" 
                        name="home" 
                        placeholder="e.g. Sapphire Estate" 
                        class="w-full pl-5 pr-12 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl text-slate-900 font-semibold placeholder-slate-300 outline-none
                               transition-all duration-300
                               focus:bg-white focus:border-blue-600 focus:shadow-[0_0_0_4px_rgba(37,99,235,0.08)]"
                    >
                    <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within/input:text-blue-600 group-focus-within/input:scale-110 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                    </div>
                </div>

                <button 
                    type="submit" 
                    name="submit"
                    class="relative w-full overflow-hidden group/btn px-6 py-4 bg-slate-900 text-white font-bold rounded-2xl transition-all duration-300 
                           hover:bg-black hover:shadow-xl active:scale-[0.98]"
                >
                    <span class="relative z-10 flex items-center justify-center gap-2">
                        Add to Collection
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </span>
                </button>
            </div>
        </div>
    </form>
</div>
</body>
</html>